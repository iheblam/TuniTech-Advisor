# TuniTech Advisor – Environment Configuration
# Copy this file to .env and fill in all values before running.

# ── Admin credentials ────────────────────────────────────────────
ADMIN_USERNAME=tuniAdmin
ADMIN_PASSWORD=Admin1234

# ── JWT security ─────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_LONG_RANDOM_STRING
JWT_EXPIRE_MINUTES=480

# ── MLflow ───────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=smartphone-price-prediction

# ── API ──────────────────────────────────────────────────────────
DEBUG=false

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# For cloud deployment add your Render/Vercel frontend URL here.
# CORS_ORIGINS=http://localhost:3000,https://tunitech.onrender.com

# ── Groq AI ──────────────────────────────────────────────────────
# Free API key from https://console.groq.com/
# Used for GSMArena image slug generation (Step 2 of image pipeline).
GROQ_API_KEY=

# ── Frontend (cloud deployment only) ────────────────────────────
# Set this when deploying the frontend to Vercel / Render static site.
# Leave empty for docker-compose (nginx proxy handles routing internally).
# Example: https://tunitech-api.onrender.com/api/v1
VITE_API_BASE_URL=

# ── Groq AI (phone suggestion feature) ─────────────────────────
# Get a free key at https://console.groq.com
# Used by the frontend for real-time phone name identification.
VITE_GROQ_API_KEY=
